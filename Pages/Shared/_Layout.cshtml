<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Kube 365系统审批配置数据校验</title>
    <link rel="stylesheet" href="https://apps.bdimg.com/libs/bootstrap/3.3.4/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-default">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbar-collapse">
                    <span class="sr-only">切换导航</span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                <span class="navbar-brand" style="padding:4px 15px;">
                    <img src="@Url.Content("~/logo.png")" height="42" alt="logo" style="display:inline-block;vertical-align:top;" />
                </span>
            </div>
            <div class="collapse navbar-collapse" id="navbar-collapse">
                <ul class="nav navbar-nav">
                    <li>
                        <a href="https://oa365.sinarmas-agri.com/" target="_blank">Kube 365</a>
                    </li>
                    <li class="@(ViewData["Title"]?.ToString() == "Kube 365系统审批配置数据校验" ? "active" : "")">
                        <a href="@Url.Content("~/")">审批配置数据冲突值检测</a>
                    </li>
                    <li class="@(ViewData["Title"]?.ToString() == "审批人一致性比对" ? "active" : "")">
                        <a href="@Url.Page("/Compare")">审批人一致性比对</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <script src="https://apps.bdimg.com/libs/jquery/2.1.4/jquery.min.js"></script>
    <script src="https://apps.bdimg.com/libs/bootstrap/3.3.4/js/bootstrap.min.js"></script>

    <hr style="margin-top:30px;" />
    <footer class="text-center" style="padding-bottom:20px;color:#999;">
        <a href="https://www.garchina.com/" target="_blank" style="color:#999;">GARCHINA网址大全</a>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
